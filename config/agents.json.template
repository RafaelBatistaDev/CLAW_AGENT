{
  "version": "1.0.1",
  "timestamp": "2026-04-07T00:00:00Z",
  "description": "Claw_Agent - Configuration with Google Gemini + Fallback Pattern + Local AI",
  "agents": [
    {
      "name": "Gemini-Flash-Primary",
      "type": "llm",
      "provider": "google",
      "model": "models/gemini-2.0-flash",
      "endpoint": "https://generativelanguage.googleapis.com/v1beta/models/gemini-2.0-flash:generateContent",
      "key": "${GOOGLE_GEMINI_API_KEY}",
      "priority": 1,
      "timeout": 120,
      "maxTokens": 8192,
      "inputTokenLimit": 1048576,
      "cost": "free-tier",
      "status": "active",
      "capabilities": [
        "analyze",
        "improve",
        "document",
        "test"
      ],
      "description": "Primary API - will be tested with automatic retry"
    },
    {
      "name": "LocalAI-Fallback",
      "type": "local",
      "provider": "local",
      "model": "local-ai",
      "priority": 2,
      "timeout": 5,
      "maxTokens": 1000,
      "status": "active",
      "capabilities": [
        "suggest",
        "fallback"
      ],
      "description": "Fallback when API fails - intelligent local responses without remote IA"
    }
  ],
  "webSearch": [
    {
      "name": "Wikipedia-Search",
      "type": "search",
      "provider": "wikipedia",
      "priority": 1,
      "timeout": 10,
      "status": "active",
      "description": "Search Wikipedia for context"
    }
  ],
  "config": {
    "retryAttempts": 3,
    "retryDelay": 3,
    "circuitBreakerThreshold": 3,
    "circuitBreakerRecoveryTimeout": 300,
    "fallbackStrategy": "LOCAL_AI_THEN_SUGGEST"
  }
}
