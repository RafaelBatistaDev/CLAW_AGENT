{
  "version": "3.0.0",
  "timestamp": "2026-04-06T18:41:00Z",
  "description": "Configura\u00e7\u00e3o com 1 API Google Gemini + Fallback Pattern + LocalAI",
  "agents": [
    {
      "name": "Gemini-Flash-Primary",
      "type": "llm",
      "provider": "google",
      "model": "models/gemini-2.0-flash",
      "endpoint": "https://generativelanguage.googleapis.com/v1beta/models/gemini-2.0-flash:generateContent",
      "key": "${GOOGLE_GEMINI_API_KEY}",
      "priority": 1,
      "timeout": 120,
      "maxTokens": 8192,
      "inputTokenLimit": 1048576,
      "cost": "free-tier",
      "status": "active",
      "capabilities": [
        "analyze",
        "improve",
        "document",
        "test"
      ],
      "description": "Chave prim\u00e1ria - ser\u00e1 testado com retry autom\u00e1tico"
    },
    {
      "name": "LocalAI-Fallback",
      "type": "local",
      "provider": "local",
      "model": "local-ai",
      "priority": 2,
      "timeout": 5,
      "maxTokens": 1000,
      "status": "active",
      "capabilities": [
        "suggest",
        "fallback"
      ],
      "description": "Fallback local quando API falha - respostas inteligentes sem IA remota"
    }
  ],
  "webSearch": [
    {
      "name": "Wikipedia-Search",
      "type": "search",
      "provider": "wikipedia",
      "priority": 1,
      "timeout": 10,
      "status": "active",
      "description": "Busca em Wikipedia para contexto"
    }
  ],
  "config": {
    "retryAttempts": 3,
    "retryDelay": 3,
    "circuitBreakerThreshold": 3,
    "circuitBreakerRecoveryTimeout": 300,
    "fallbackStrategy": "LOCAL_AI_THEN_SUGGEST"
  }
}