#!/usr/bin/env python3
"""
🚀 CLAW Agent — Entry point minimalista
Aponta direto para automation/my_scripts/agent.py
"""
import sys
import subprocess
from pathlib import Path

project_root = Path(__file__).parent.parent
agent_path = project_root / "automation" / "my_scripts" / "agent.py"

if not agent_path.exists():
    print(f"❌ Erro: agent.py não encontrado em {agent_path}")
    sys.exit(1)

sys.exit(subprocess.call([sys.executable, str(agent_path)] + sys.argv[1:]))
