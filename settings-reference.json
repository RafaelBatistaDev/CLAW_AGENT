{
  "clawrafaelia": {
    "enabled": {
      "type": "boolean",
      "default": true,
      "description": "Ativar/desativar sugestões inline da CLAW",
      "example": true
    },
    "debounceMs": {
      "type": "number",
      "default": 500,
      "min": 100,
      "max": 5000,
      "description": "Milissegundos para aguardar após última tecla antes de sugerir",
      "examples": [
        "100 (rápido, mais API calls)",
        "500 (recomendado)",
        "2000 (econômico)"
      ]
    },
    "maxTokens": {
      "type": "number",
      "default": 50,
      "min": 10,
      "max": 200,
      "description": "Máximo de tokens por sugestão. Reduz custo de API.",
      "examples": [
        "10 (muito curto, ~40 chars)",
        "50 (padrão, ~200 chars)",
        "200 (longo, ~800 chars)"
      ]
    },
    "languages": {
      "type": "object",
      "default": {
        "python": true,
        "typescript": true,
        "javascript": true,
        "csharp": true,
        "rust": true,
        "go": true,
        "sql": true,
        "markdown": true,
        "java": true,
        "bash": true
      },
      "description": "Ativar/desativar sugestões por linguagem",
      "note": "Desativar linguagens não usadas para economizar cache"
    },
    "autoDetectAI": {
      "type": "boolean",
      "default": true,
      "description": "Auto-detectar IAs disponíveis na inicialização",
      "note": "Recomendado ligado para melhor experiência"
    },
    "preferredAI": {
      "type": "string",
      "default": "auto",
      "enum": ["auto", "gemini", "openai", "claude", "localai", "ollama", "pattern", "template"],
      "description": "Preferir uma IA específica em vez de auto-detectar",
      "examples": [
        "auto   (detecta automaticamente)",
        "gemini (força Gemini)",
        "openai (força OpenAI)",
        "pattern (pula diretamente para pattern matching)"
      ]
    },
    "aiTimeout": {
      "type": "number",
      "default": 2000,
      "min": 500,
      "max": 10000,
      "description": "Timeout em ms para chamadas IA",
      "note": "Evitar ser muito baixo para APIs lentas"
    },
    "enableCache": {
      "type": "boolean",
      "default": true,
      "description": "Ativar cache semântico local",
      "note": "Economiza 60%+ de chamadas de API"
    },
    "cacheSimilarityThreshold": {
      "type": "number",
      "default": 0.75,
      "min": 0.5,
      "max": 1.0,
      "description": "Threshold para reusar sugestão do cache (0-1)",
      "examples": [
        "0.5 (muito permissivo, reusa bastante)",
        "0.75 (recomendado)",
        "0.95 (muito rigoroso, reusa pouco)"
      ]
    },
    "cacheMaxEntries": {
      "type": "number",
      "default": 500,
      "min": 100,
      "max": 5000,
      "description": "Máximo de entradas no cache local",
      "note": "Mais entradas = mais RAM, melhor hit rate"
    },
    "enablePattern": {
      "type": "boolean",
      "default": true,
      "description": "Ativar pattern matching como fallback",
      "note": "Sempre ativa em offline"
    },
    "enableTemplate": {
      "type": "boolean",
      "default": true,
      "description": "Ativar template fallback",
      "note": "Último recurso quando tudo falha"
    },
    "enableLocalAI": {
      "type": "boolean",
      "default": true,
      "description": "Ativar detecção de LocalAI/Ollama",
      "note": "Verificar se você tem rodando em localhost"
    },
    "localAIEndpoint": {
      "type": "string",
      "default": "http://localhost:8000",
      "description": "Endpoint do LocalAI",
      "examples": [
        "http://localhost:8000 (LocalAI padrão)",
        "http://localhost:11434 (Ollama padrão)",
        "http://192.168.1.100:8000 (LocalAI remoto)"
      ]
    },
    "ollamaEndpoint": {
      "type": "string",
      "default": "http://localhost:11434",
      "description": "Endpoint do Ollama",
      "note": "Detecção automática se Ollama rodando em porta padrão"
    },
    "logLevel": {
      "type": "string",
      "default": "info",
      "enum": ["debug", "info", "warn", "error"],
      "description": "Nível de logging",
      "examples": [
        "debug (verboso, para debugging)",
        "info  (padrão, informações úteis)",
        "warn  (apenas avisos)",
        "error (apenas erros)"
      ]
    },
    "showStatusBar": {
      "type": "boolean",
      "default": true,
      "description": "Mostrar status bar com informações de CLAW",
      "note": "Clique para abrir painel de status"
    },
    "showInlineMessage": {
      "type": "boolean",
      "default": true,
      "description": "Mostrar mensagem inline com fonte da sugestão",
      "note": "(cache), (gemini), (pattern), etc"
    },
    "acceptKeybinding": {
      "type": "string",
      "default": "Tab",
      "description": "Atalho para aceitar sugestão",
      "note": "VS Code padrão, não recomendado mudar"
    },
    "rejectKeybinding": {
      "type": "string",
      "default": "Escape",
      "description": "Atalho para rejeitar sugestão",
      "note": "VS Code padrão"
    },
    "toggleKeybinding": {
      "type": "string",
      "default": "ctrl+alt+c",
      "description": "Atalho para toggle CLAW on/off",
      "note": "Customizável em keybindings.json"
    },
    "circuitBreakerThreshold": {
      "type": "number",
      "default": 5,
      "min": 1,
      "max": 20,
      "description": "Quantas falhas antes de blacklistear uma IA",
      "examples": [
        "2 (muito sensível, muda IA frequentemente)",
        "5 (recomendado)",
        "20 (tolerante, tenta bastante)"
      ]
    },
    "circuitBreakerTimeout": {
      "type": "number",
      "default": 300000,
      "description": "Timeout em ms antes de tentar IA novamente (5min = 300000ms)",
      "examples": [
        "60000  (1 min, tenta logo)",
        "300000 (5 min, recomendado)",
        "600000 (10 min, espera mais)"
      ]
    },
    "excludePatterns": {
      "type": "array",
      "default": ["*.test.js", "*.spec.ts", "node_modules/**", "dist/**"],
      "description": "Padrões de arquivo para excluir de sugestões",
      "note": "Evita sugerir em testes ou build directories"
    },
    "httpProxyUrl": {
      "type": "string",
      "default": "",
      "description": "URL de proxy HTTP/HTTPS (opcional)",
      "example": "http://proxy.company.com:8080",
      "note": "Se deixado vazio, usa configuração do VS Code"
    },
    "Analytics": {
      "enabled": {
        "type": "boolean",
        "default": true,
        "description": "Coletar métricas anônimas"
      },
      "sendUrl": {
        "type": "string",
        "default": "",
        "description": "URL webhook para enviar métricas (opcional)",
        "note": "Deixar vazio para armazenar localmente apenas"
      }
    }
  },
  "example_configurations": {
    "para_iniciar": {
      "clawrafaelia.enabled": true,
      "clawrafaelia.debounceMs": 500,
      "clawrafaelia.autoDetectAI": true
    },
    "para_economizar_api": {
      "clawrafaelia.maxTokens": 30,
      "clawrafaelia.debounceMs": 1000,
      "clawrafaelia.enableCache": true,
      "clawrafaelia.cacheSimilarityThreshold": 0.8
    },
    "offline_apenas": {
      "clawrafaelia.preferredAI": "pattern",
      "clawrafaelia.enableCache": true,
      "clawrafaelia.enableLocalAI": false
    },
    "openai_rapido": {
      "clawrafaelia.preferredAI": "openai",
      "clawrafaelia.aiTimeout": 3000,
      "clawrafaelia.debounceMs": 300,
      "clawrafaelia.maxTokens": 100
    },
    "localhost_localai": {
      "clawrafaelia.preferredAI": "localai",
      "clawrafaelia.localAIEndpoint": "http://localhost:8000",
      "clawrafaelia.enableCache": true,
      "clawrafaelia.debounceMs": 500
    },
    "localai_remoto": {
      "clawrafaelia.preferredAI": "localai",
      "clawrafaelia.localAIEndpoint": "http://192.168.1.100:8000",
      "clawrafaelia.aiTimeout": 5000,
      "clawrafaelia.debounceMs": 1000
    },
    "empresa_openai": {
      "clawrafaelia.preferredAI": "openai",
      "clawrafaelia.httpProxyUrl": "http://proxy.company.com:8080",
      "clawrafaelia.maxTokens": 75,
      "clawrafaelia.Circuit BreakerThreshold": 3
    },
    "debug_mode": {
      "clawrafaelia.logLevel": "debug",
      "clawrafaelia.showInlineMessage": true,
      "clawrafaelia.showStatusBar": true,
      "clawrafaelia.debounceMs": 1000
    }
  },
  "environment_variables": {
    "OPENAI_API_KEY": {
      "description": "Chave da API OpenAI",
      "example": "sk-proj-xxxxxxxxxxxxx"
    },
    "ANTHROPIC_API_KEY": {
      "description": "Chave da API Anthropic (Claude)",
      "example": "sk-ant-xxxxxxxxxxxxx"
    },
    "GOOGLE_GEMINI_API_KEY": {
      "description": "Chave da API Google Gemini",
      "example": "AIzaSy..."
    },
    "CLAW_HOME": {
      "description": "Localização custom para cache CLAW",
      "default": "~/.claw/cache",
      "example": "/opt/claw/cache"
    },
    "CLAW_LOG_DIR": {
      "description": "Localização custom para logs",
      "default": "~/.claw/logs",
      "example": "/var/log/claw"
    }
  },
  "notes": {
    "API_Keys": "Armazenar em variáveis de ambiente ou ~/.claw/config/.claude.json, NÃO em settings.json",
    "Performance": "Para máx performance: cache=true, debounce=500ms, maxTokens=50, preferredAI=gemini",
    "Privacy": "Offline=true: preferredAI=pattern, enableCache=false, enableLocalAI=false",
    "Debugging": "Ligar logLevel=debug em .vscode/launch.json para troubleshooting",
    "Conflicts": "CLAW compatível com GitHub Copilot, ambas podem rodar simultaneamente"
  },
  "version": "1.1.3",
  "last_updated": "2026-04-06"
}
